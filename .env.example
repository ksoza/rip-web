# ================================================================
# RiP -- Remix I.P. | AI Fan Studio
# Copy to .env.local and fill in your keys
# ================================================================

# -- SUPABASE ---------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=               # Get from: Supabase Dashboard -> Settings -> API -> URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=          # Get from: Supabase Dashboard -> Settings -> API -> anon public
SUPABASE_SERVICE_ROLE_KEY=              # Get from: Supabase Dashboard -> Settings -> API -> service_role (KEEP SECRET)

# -- STRIPE -----------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=     # Get from: Stripe Dashboard -> API Keys
STRIPE_SECRET_KEY=                      # Get from: Stripe Dashboard -> API Keys (KEEP SECRET)
STRIPE_WEBHOOK_SECRET=                  # Created after setting up webhook endpoint

# Stripe Price IDs (create in Stripe Dashboard -> Products)
STRIPE_PRICE_STARTER=                   # Starter -- $1/week
STRIPE_PRICE_CREATOR=                   # Creator -- $5/month
STRIPE_PRICE_STUDIO=                    # Studio  -- $10/month

# -- NEXOS.AI GATEWAY (recommended -- single key for 200+ models)
NEXOS_API_KEY=                          # Get from: nexos.ai -> Dashboard -> API Keys
NEXOS_BASE_URL=https://api.nexos.ai/v1 # Default gateway endpoint (change only for self-hosted)

# -- ANTHROPIC --------------------------------------------------
ANTHROPIC_API_KEY=                      # Get from: console.anthropic.com -> API Keys
# (Fallback if NEXOS_API_KEY not set)

# -- HUGGINGFACE ------------------------------------------------
HUGGINGFACE_API_KEY=                    # Get from: huggingface.co/settings/tokens

# -- FAL.AI (Video Generation -- Veo 3.1, Seedance 2) ----------
FAL_KEY=                                # Get from: fal.ai -> Dashboard -> Keys (REQUIRED for video gen)

# -- VOXCPM (Self-Hosted TTS -- Voice Design + Voice Cloning) --
# VoxCPM is the primary TTS provider. Self-hosted = zero ongoing cost.
# Deploy Nano-vLLM server on Vast.ai RTX 4090 (~$0.25/hr)
# See: https://github.com/OpenBMB/VoxCPM
VOXCPM_API_URL=                         # Self-hosted Nano-vLLM server URL (e.g., http://gpu-server:8000)
# Falls back to HuggingFace Inference API if VOXCPM_API_URL not set

# -- RAGFLOW (Show Knowledge Base -- self-hosted RAG engine) ----
# RAGflow provides per-show knowledge bases (scripts, character profiles, visual refs)
# Enriches scene generation prompts with accurate show details via RAG
# Deploy: docker compose up -d (see https://github.com/infiniflow/ragflow)
RAGFLOW_API_URL=                        # Self-hosted RAGflow URL (e.g., http://ragflow-server:9380)
RAGFLOW_API_KEY=                        # Get from: RAGflow UI -> User Settings -> API Key

# -- AI PROVIDERS -----------------------------------------------
OPENAI_API_KEY=                         # Get from: platform.openai.com -> API Keys (DALL-E 3)
REPLICATE_API_TOKEN=                    # Get from: replicate.com -> Account -> API Tokens
ELEVENLABS_API_KEY=                     # Get from: elevenlabs.io -> Profile -> API Key
LUMA_API_KEY=                           # Get from: lumalabs.ai -> API -> Keys
RUNWAY_API_KEY=                         # Get from: dev.runwayml.com -> API Keys
XAI_API_KEY=                            # Get from: console.x.ai -> API Keys (Grok)

# -- TMDB (Movie/TV metadata + posters) -------------------------
TMDB_API_KEY=                           # Get from: themoviedb.org -> Settings -> API -> API Key (v3)
TMDB_READ_ACCESS_TOKEN=                 # Get from: themoviedb.org -> Settings -> API -> Read Access Token (v4)

# -- N8N (Workflow automation) -----------------------------------
N8N_WEBHOOK_URL=                        # Your n8n instance base URL (e.g. https://your-n8n.app.n8n.cloud)
N8N_API_KEY=                            # Get from: n8n -> Settings -> API Keys

# -- SOLANA / WEB3 ----------------------------------------------
NEXT_PUBLIC_SOLANA_RPC=                 # Solana RPC URL (e.g. https://api.mainnet-beta.solana.com)
NEXT_PUBLIC_FOUNDER_WALLET=             # Founder wallet address for revenue split
FOUNDER_SOLANA_WALLET=                  # Same as above, used server-side

# -- AIRBYTE (Data Pipeline -- optional) -------------------------
AIRBYTE_API_KEY=                        # Get from: Airbyte Cloud -> Settings -> API Keys
AIRBYTE_WORKSPACE_ID=                   # Get from: Airbyte Cloud -> Workspace -> Settings

# -- SEARCH (optional -- for GhOSTface web search) ---------------
TAVILY_API_KEY=                         # Get from: tavily.com -> API Keys

# -- APP ---------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://www.remixip.icu
